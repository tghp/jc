{
    "name": "tghp/jc-project",
    "type": "project",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packagist.org"
        },
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "require": {
        "johnpbloch/wordpress": "6.9.4",
        "tghp/wp-composer-clean": "^2.1",
        "vlucas/phpdotenv": "^5",
        "wpackagist-plugin/wordfence": "^8",
        "monolog/monolog": "^2",
        "wpackagist-plugin/wp-gatsby": "2.3.3",
        "wpackagist-plugin/wp-graphql": "^2.5",
        "wpackagist-plugin/wp-rest-api-v2-menus": "0.12.1",
        "tghp/wp-graphql-mb-tghp": "2.6.0",
        "tghp/wp-gatsby-tghp": "1.4.0",
        "wpackagist-plugin/wordpress-seo": "27.1.1",
        "wpackagist-plugin/add-wpgraphql-seo": "^4.18"
    },
    "config": {
        "vendor-dir": "wp-content/vendor",
        "allow-plugins": {
            "johnpbloch/wordpress-core-installer": true,
            "composer/installers": true,
            "tghp/wp-composer-clean": true,
            "kylekatarnls/update-helper": true
        }
    },
    "extra": {
        "wordpress-install-dir": "wp",
        "installer-paths": {
            "wp-content/plugins/{$name}/": [
                "type:wordpress-plugin"
            ],
            "wp-content/themes/{$name}/": [
                "type:wordpress-theme"
            ]
        }
    }
}
